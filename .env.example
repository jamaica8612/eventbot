VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
# 댓글 후보 자동 생성에 사용. 비워두면 영상 정보/백업 transcript만 표시되고 댓글 후보는 비활성화.
GEMINI_API_KEY=
YOUTUBE_API_KEY=
EVENTBOT_PASSCODE=
# GitHub Pages 같은 정적 배포에서 댓글 후보 API를 별도 서버/Vercel로 붙일 때 사용합니다.
# 비워두면 localhost는 현재 origin의 /api/youtube-transcript를,
# 배포판은 Supabase Edge Function /functions/v1/youtube-transcript를 호출합니다.
VITE_API_BASE_URL=

# 텔레그램 신규 이벤트 알림 (크롤러가 새 이벤트를 텔레그램으로 발송)
# 1) @BotFather 에게 /newbot 으로 봇 생성 후 토큰 발급
# 2) 봇에게 아무 메시지나 보낸 뒤 https://api.telegram.org/bot<토큰>/getUpdates 에서 chat id 확인
# 두 값이 모두 있어야 알림이 동작하고, 비워두면 알림 단계는 조용히 건너뜁니다.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 알림 폭주 방지(선택): 클릭 점수 하한과 1회 실행당 최대 발송 개수. 비우면 기본값(60 / 8) 사용.
TELEGRAM_NOTIFY_MIN_SCORE=
TELEGRAM_MAX_NOTIFICATIONS_PER_RUN=
