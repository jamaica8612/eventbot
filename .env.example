VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
# 댓글 후보 자동 생성에 사용. 비워두면 영상 정보/백업 transcript만 표시되고 댓글 후보는 비활성화.
GEMINI_API_KEY=
# GitHub Pages 같은 정적 배포에서 댓글 후보 API를 별도 서버/Vercel로 붙일 때 사용합니다.
# 비워두면 localhost는 현재 origin의 /api/youtube-transcript를,
# 배포판은 Supabase Edge Function /functions/v1/youtube-transcript를 호출합니다.
VITE_API_BASE_URL=
