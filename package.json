{
  "name": "event-click-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "crawl:suto": "node crawler/sutoCrawler.js",
    "crawl:suto:youtube": "node -e \"process.env.SUTO_YOUTUBE_TRANSCRIPT_LIMIT='1'; import('./crawler/sutoCrawler.js')\"",
    "crawl:suto:body": "node crawler/sutoBrowserCrawler.js",
    "crawl:hotdeal": "node crawler/hotdealCrawler.js",
    "crawl:full": "node scripts/crawlFull.js",
    "backfill:announcement": "node scripts/backfillAnnouncementDates.js",
    "verify:supabase": "node scripts/verifySupabase.js",
    "telegram:test": "node scripts/sendTestTelegram.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "simple-icons": "^16.19.0",
    "vite": "^7.1.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^3.0.5"
  }
}
